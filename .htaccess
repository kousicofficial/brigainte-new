# ------------------------------------------------------------------------------
# Security and URL Optimizations
# ------------------------------------------------------------------------------

<IfModule mod_rewrite.c>
    # Enable Rewrite Engine
    RewriteEngine On
    RewriteBase /

    # 1. Force HTTPS redirection
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2 & 3. Remove .html extensions and Redirect .html to non-extension
    # Redirect internal *.html requests to clean version (301 redirect)
    RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
    RewriteRule ^ %1 [L,R=301]

    # Internally map clean URLs to .html files
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# 4. Disable directory listing
Options -Indexes

# 5. Block access to sensitive files
<FilesMatch "\.(htaccess|ini|log|sql|bak|config|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# 6. Enable basic security headers
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>
